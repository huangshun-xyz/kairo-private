{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 29,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ios-demo-xcode",
      "displayName": "iOS Demo (Xcode Simulator)",
      "description": "Generates the standalone iOS demo Xcode project.",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/../../build/ios_sim",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "16.0"
      }
    }
  ]
}
